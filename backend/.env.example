APP_NAME="RentConnect Burundi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Master Database (Write Operations)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rentconnect_burundi
DB_USERNAME=root
DB_PASSWORD=

# Slave Database (Read Operations)
DB_READ_HOST=127.0.0.1
DB_READ_PORT=3307
DB_READ_DATABASE=rentconnect_burundi
DB_READ_USERNAME=root
DB_READ_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# Mobile Money API Keys (Lumicash/Econet)
LUMICASH_API_KEY=
LUMICASH_API_SECRET=
ECONET_API_KEY=
ECONET_API_SECRET=
